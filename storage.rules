rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /agenda/{eventId}/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    match /historico/{recordId}/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    match /galeria/{setId}/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    match /social/{postId}/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
