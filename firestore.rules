rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /agendaEvents/{eventId} {
      allow read, write: if request.auth != null;
    }
    match /socialPosts/{postId} {
      allow read, write: if request.auth != null;
    }
    match /historyRecords/{recordId} {
      allow read, write: if request.auth != null;
    }
    match /galeriaSets/{setId} {
      allow read, write: if request.auth != null;
    }
    match /users/{userId} {
      // Qualquer utilizador autenticado lê perfis (lista para equipas / modais).
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false;
    }
    match /users/{userId}/dailyChecklistItems/{itemId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /teamIntegrantes/{docId} {
      allow read, write: if request.auth != null;
    }
    match /emailInvites/{docId} {
      allow read, write: if request.auth != null;
    }
  }
}
