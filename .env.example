# Copie para `.env.local` e preencha (Firebase Console → Definições do projeto → Suas aplicações → SDK).
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Credencial de serviço Firebase (servidor — seed, API upload R2 — nunca no cliente).
# FIREBASE_SERVICE_ACCOUNT_JSON tem prioridade sobre GOOGLE_APPLICATION_CREDENTIALS (útil no Windows).
# GOOGLE_APPLICATION_CREDENTIALS=C:\caminho\serviceAccount.json
# ou FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Cloudflare R2 (API S3 — apenas servidor; não usar NEXT_PUBLIC_ nas chaves secretas)
# R2_ACCOUNT_ID=
# R2_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
# R2_PUBLIC_BASE_URL=https://pub-xxxx.r2.dev